rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /companies/{companyId}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /charity-documents/{fileName} {
      allow write: if request.auth != null;
      allow read: if request.auth != null && request.auth.token.email == 'solarastra.in@gmail.com';
    }
  }
}

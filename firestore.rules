rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }
    
    function isRealUser() {
      return isSignedIn() && request.auth.token.firebase.sign_in_provider != 'anonymous';
    }
    
    function isPlatformAdmin() {
      return isSignedIn() && request.auth.token.email == 'solarastra.in@gmail.com';
    }

    match /platform/{document=**} {
      allow read, write: if isPlatformAdmin();
    }

    match /users/{userId} {
      allow read: if isSignedIn();
      // Only allow writes to an explicit allowlist of safe, non-impact fields
      allow write: if isRealUser() && request.auth.uid == userId &&
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['name', 'userSkills', 'photoURL', 'notificationPrefs', 'updatedAt']);
    }

    match /users/{userId}/summary/impact {
      allow read: if isSignedIn();
      allow write: if false; // server (Admin SDK) only
    }
    
    match /users/{userId}/reflections/{reflectionId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    match /users/{userId}/impactLedger/{id} {
      allow read: if isSignedIn() && request.auth.uid == userId;
      allow write: if false; // server (Admin SDK) only
    }

    match /users/{userId}/impactLedger/{ledgerId} {
      allow read: if isSignedIn() && request.auth.uid == userId;
      allow write: if false; // Only written via server-side API
    }

    match /projectChats/{projectId}/messages/{messageId} {
      allow read: if isSignedIn();
      allow write: if isRealUser();
    }

    match /milestones/{milestoneId} {
      allow read: if isSignedIn();
      allow create: if isRealUser() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if false;
    }

    match /ergs/{ergId} {
      allow read: if isSignedIn();
      allow write: if isPlatformAdmin() || isRealUser(); // Simplify for demo, ideally company_admin or erg_lead
    }
    match /companies/{companyId} {
      allow read: if true;
      allow write: if isPlatformAdmin() || (isRealUser() && request.auth.token.email in resource.data.adminEmails);
    }
    
    match /companies/{companyId}/secrets/{secretId} {
      allow read, write: if false; // Only accessed via server-side Admin SDK
    }

    match /charities/{charityId} {
      allow read: if true;
      allow write: if isPlatformAdmin();
    }

    match /projects/{projectId} {
      allow read: if true;
      allow write: if isPlatformAdmin();
    }
  }
}

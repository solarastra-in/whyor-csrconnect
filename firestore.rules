rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }
    
    function isRealUser() {
      return isSignedIn() && request.auth.token.firebase.sign_in_provider != 'anonymous';
    }
    
    function isCompanyMember(companyId) {
      return isRealUser() && (
        request.auth.token.companyId == companyId ||
        (exists(/databases/$(database)/documents/companies/$(companyId)) && 
         request.auth.token.email in get(/databases/$(database)/documents/companies/$(companyId)).data.adminEmails)
      );
    }
    
    function isPlatformAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'solarastra.in@gmail.com' ||
        (exists(/databases/$(database)/documents/platformConfig/admins) &&
         request.auth.token.email in get(/databases/$(database)/documents/platformConfig/admins).data.superAdmins)
      );
    }
    
    function isPlatformStaff() {
      return isSignedIn() && (
        isPlatformAdmin() ||
        (exists(/databases/$(database)/documents/platformConfig/admins) &&
         request.auth.token.email in get(/databases/$(database)/documents/platformConfig/admins).data.staff)
      );
    }
    
    function isNgoAdmin(charityId) {
      return isSignedIn() && exists(/databases/$(database)/documents/charities/$(charityId)) && (
        (get(/databases/$(database)/documents/charities/$(charityId)).data.adminEmails != null && 
         request.auth.token.email in get(/databases/$(database)/documents/charities/$(charityId)).data.adminEmails) ||
        (get(/databases/$(database)/documents/charities/$(charityId)).data.submittedBy != null && 
         request.auth.uid == get(/databases/$(database)/documents/charities/$(charityId)).data.submittedBy)
      );
    }
  

    match /platform/{document=**} {
      allow read, write: if isPlatformStaff() || isPlatformAdmin();
    }
    match /platformConfig/{document=**} {
      allow read: if isPlatformStaff();
      allow write: if isPlatformAdmin();
    }

    match /users/{userId} {
      allow read: if isSignedIn();
      // Only allow writes to an explicit allowlist of safe, non-impact fields
      allow write: if isSignedIn() && request.auth.uid == userId;
    }

    match /users/{userId}/summary/impact {
      allow read: if isSignedIn();
      allow write: if false; // server (Admin SDK) only
    }
    
    match /users/{userId}/reflections/{reflectionId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    match /users/{userId}/impactLedger/{id} {
      allow read: if isSignedIn() && request.auth.uid == userId;
      allow write: if false; // server (Admin SDK) only
    }

    match /users/{userId}/impactLedger/{ledgerId} {
      allow read: if isSignedIn() && request.auth.uid == userId;
      allow write: if false; // Only written via server-side API
    }

    match /projectChats/{projectId}/messages/{messageId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    match /milestones/{milestoneId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if false;
    }

    match /ergs/{ergId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isPlatformAdmin() || isCompanyMember(resource.data.companyId);
    }
    match /companies/{companyId}/campaigns/{campaignId} {
      allow read: if isSignedIn();
      allow write: if isPlatformAdmin() || isCompanyMember(companyId);
    }
    match /companies/{companyId}/config/{configId} {
      allow read: if isSignedIn();
      allow write: if isPlatformAdmin() || isCompanyMember(companyId);
    }
    match /skillVerifications/{id} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isPlatformAdmin() || (isRealUser() && resource.data.companyId == request.auth.token.companyId);
    }
    match /companies/{companyId} {
      allow read: if true;
      allow create: if isRealUser() && request.auth.token.email in request.resource.data.adminEmails && request.resource.data.status == 'pending_review';
      allow update: if isPlatformAdmin() || (isRealUser() && request.auth.token.email in resource.data.adminEmails);
      allow delete: if isPlatformAdmin();
    }
    
    match /companies/{companyId}/secrets/{secretId} {
      allow read, write: if false; // Only accessed via server-side Admin SDK
    }

    match /charities/{charityId} {
      allow read: if true;
      allow create: if isRealUser() && request.resource.data.status == 'pending_verification' && request.resource.data.submittedBy == request.auth.uid;
      allow update: if isPlatformAdmin() || isNgoAdmin(charityId);
      allow delete: if isPlatformAdmin();
    }

    match /projects/{projectId} {
      allow read: if true;
      allow create: if isPlatformAdmin() || isPlatformStaff() || (isSignedIn() && exists(/databases/$(database)/documents/charities/$(request.resource.data.charityId)) && request.auth.token.email in get(/databases/$(database)/documents/charities/$(request.resource.data.charityId)).data.adminEmails);
      allow update, delete: if isPlatformAdmin() || isPlatformStaff() || (isSignedIn() && exists(/databases/$(database)/documents/charities/$(resource.data.charityId)) && request.auth.token.email in get(/databases/$(database)/documents/charities/$(resource.data.charityId)).data.adminEmails);
    }
    
    match /commitments/{commitmentId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    match /payments/{paymentId} {
      allow read: if isPlatformStaff() || (isSignedIn() && (
        resource.data.companyId == request.auth.token.companyId || 
        (resource.data.ngoId != null && isNgoAdmin(resource.data.ngoId)) || 
        (resource.data.charityId != null && isNgoAdmin(resource.data.charityId))
      ));
      allow create: if isCompanyMember(request.resource.data.companyId) || isPlatformAdmin();
      allow update: if isPlatformAdmin() || isPlatformStaff();
    }

    match /grants/{grantId} {
      allow read: if isSignedIn();
      allow create: if isCompanyMember(request.resource.data.companyId) || 
        request.resource.data.companyId == 'general_pool' ||
        (isSignedIn() && isNgoAdmin(request.resource.data.ngoId));
      allow update, delete: if isPlatformAdmin() || isCompanyMember(resource.data.companyId) ||
        (resource.data.companyId == 'general_pool' && (isPlatformAdmin() || isPlatformStaff()));
    }
  }
}
